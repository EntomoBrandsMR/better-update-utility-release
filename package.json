{
  "name": "better-update-utility",
  "version": "1.2.4",
  "description": "Better Update Utility — PestPac automation",
  "author": "Entomo Brands",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps && npx playwright install chromium"
  },
  "build": {
    "appId": "com.entomobands.better-update-utility",
    "productName": "Better Update Utility",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "forceCodeSigning": false,
      "cscLink": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "build/installer.nsh"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "chromium",
        "to": "chromium"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "asarUnpack": [
      "node_modules/playwright-core/**/*",
      "node_modules/xlsx/**/*",
      "node_modules/keytar/**/*",
      "node_modules/csv-parse/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "exceljs": "^4.4.0"
  },
  "dependencies": {
    "csv-parse": "^5.5.0",
    "keytar": "^7.9.0",
    "playwright-core": "^1.59.1",
    "xlsx": "^0.18.5"
  }
}
